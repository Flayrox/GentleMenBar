RewriteEngine On

# Forcer HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Rediriger www vers non-www (domaine principal)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Canonicaliser les anciennes URLs de match vers la nouvelle forme courte
RewriteRule ^matchs/dates/([^/]+)/?$ /matchs/$1 [L,R=301,NC]

# Réécriture SEO pour pages de match
RewriteRule ^matchs/([^/]+)/?$ /match.php?slug=$1 [L,QSA,NC]

# Accès privé masqué
RewriteCond %{THE_REQUEST} \s/+admin(?:\.php)?[\s?] [NC]
RewriteRule ^(?:admin(?:\.php)?)$ /le-comptoir [L,R=301,NC]
RewriteRule ^le-comptoir/?$ /admin.php [L,QSA,NC]

# Optionnel : rediriger index.php vers /
RewriteCond %{THE_REQUEST} /index\.php [NC]
RewriteRule ^index\.php$ / [L,R=301]
