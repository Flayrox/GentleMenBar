RewriteEngine On

# Forcer HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Rediriger www vers non-www (domaine principal)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Réécriture SEO pour pages de match
RewriteRule ^matchs/dates/([^/]+)/?$ /match.php?slug=$1 [L,QSA,NC]

# Accès simplifié à l'administration
RewriteRule ^admin/?$ /admin.php [L,QSA,NC]

# Optionnel : rediriger index.php vers /
RewriteCond %{THE_REQUEST} /index\.php [NC]
RewriteRule ^index\.php$ / [L,R=301]
